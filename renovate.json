{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "prConcurrentLimit": 0,
  "reviewers": [
    "chik4ge"
  ],
  "assignees": [
    "chik4ge"
  ],
  "argocd": {
    "managerFilePatterns": [
      "/templates/.+\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/manifests/.+\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/mixins/build/grafana/github-dashboards\\.yaml$/"
      ],
      "matchStrings": [
        "version:\\s*(?<currentValue>\\S+)\\s*#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "disable patch automerge for ceph and cuda related deps",
      "matchPackageNames": [
        "/.*ceph.*/",
        "/.*cuda.*/"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": false
    },
    {
      "description": "automerge patch updates",
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": true
    },
    {
      "matchPackageNames": [
        "loki"
      ],
      "fetchChangeLogs": "off",
      "prBodyNotes": [
        "helm chart changelogs: https://redirect.github.com/grafana/loki/blob/main/production/helm/loki/CHANGELOG.md#{{{replace '\\.' '' newVersion}}}",
        "loki changelogs: https://redirect.github.com/grafana/loki/blob/main/CHANGELOG.md"
      ]
    },
    {
      "matchPackageNames": [
        "grafana"
      ],
      "prBodyNotes": [
        "grafana changelogs: https://redirect.github.com/grafana/grafana/blob/main/CHANGELOG.md"
      ]
    },
    {
      "matchPackageNames": [
        "mimir"
      ],
      "fetchChangeLogs": "off",
      "prBodyNotes": [
        "helm chart changelogs: https://github.com/grafana/mimir/blob/main/operations/helm/charts/mimir-distributed/CHANGELOG.md#{{{replace '\\.' '' newVersion}}}",
        "mimir changelogs: https://redirect.github.com/grafana/mimir/blob/main/CHANGELOG.md"
      ]
    },
    {
      "matchPackageNames": [
        "alloy"
      ],
      "fetchChangeLogs": "off",
      "prBodyNotes": [
        "helm chart changelogs: https://github.com/grafana/alloy/blob/main/operations/helm/charts/alloy/CHANGELOG.md",
        "alloy changelogs: https://redirect.github.com/grafana/alloy/blob/main/CHANGELOG.md"
      ]
    },
    {
      "matchPackageNames": [
        "tailscale-operator"
      ],
      "fetchChangeLogs": "off",
      "prBodyNotes": [
        "changelogs: https://tailscale.com/changelog#service"
      ]
    }
  ]
}
